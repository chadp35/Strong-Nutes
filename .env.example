# Copy this file to .env and fill in your own Supabase project's values.
# Find these in your Supabase dashboard under Project Settings > API.
# The anon key is safe to expose in client-side code — Row Level Security
# (set up by supabase/schema.sql) is what actually protects each user's data.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
